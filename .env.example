GITHUB_USERNAME=            # your GitHub username
GITHUB_STARTUPS_REPO=       # username/repo for startup source codes (Engineer agent)
GITHUB_MODELS_TOKEN=        # fine-grained PAT, Models read-only (LLM calls)
GITHUB_TOKEN=               # classic PAT, repo scope (Engineer agent)
SLACK_BOT_TOKEN=            # xoxb- token (Marketing agent)
SENDGRID_API_KEY=           # SG. key (Marketing agent)
SENDGRID_FROM_EMAIL=        # verified sender email in SendGrid (Marketing agent)
MARKETING_TEST_EMAIL=       # email to receive cold outreach (Marketing agent)